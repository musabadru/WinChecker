<Page
    x:Class="WinChecker.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinChecker.App.ViewModels"
    xmlns:models="using:WinChecker.Core"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <animations:Implicit.ShowAnimations>
        <animations:TranslationAnimation From="0,100,0" To="0,0,0" Duration="0:0:0.25" />
        <animations:OpacityAnimation From="0" To="1" Duration="0:0:0.25" />
    </animations:Implicit.ShowAnimations>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="1000*" MaxWidth="1600" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="1" Margin="32,0,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="Auto"/> <!-- Toolbar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- 3. Page Header -->
            <Grid Grid.Row="0" Margin="0,32,0,24" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0" Glyph="&#xE71D;" FontSize="50" Width="60" Height="60" 
                          Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                    <TextBlock Text="Installed Applications" 
                               FontFamily="Segoe UI Variable Display"
                               FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="Browse and analyze installed Win32 and UWP applications on your system." 
                               FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <Button Grid.Column="2" VerticalAlignment="Center" 
                        Command="{x:Bind ViewModel.ScanAppsCommand}"
                        Style="{ThemeResource SubtleButtonStyle}"
                        ToolTipService.ToolTip="Refresh application list">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                </Button>
            </Grid>

            <!-- 5. List Toolbar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12" Spacing="12">
                <AutoSuggestBox PlaceholderText="Search applications..." 
                                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                QueryIcon="Find"
                                Width="300"
                                VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 7. Data List Area -->
            <Grid Grid.Row="2">
                <!-- Page-Level Loading Indicator -->
                <ProgressBar VerticalAlignment="Top" 
                             IsIndeterminate="True" 
                             Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             Margin="1,-6,1,0" Canvas.ZIndex="1"/>

                <ListView ItemsSource="{x:Bind ViewModel.Apps}"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemClick="OnAppClicked"
                          Padding="0,0,0,12">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:InstalledApp">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,8" 
                                    HorizontalAlignment="Stretch">
                                <Border.BackgroundTransition>
                                    <BrushTransition Duration="0:0:0.083" />
                                </Border.BackgroundTransition>
                                
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" Width="40" Height="40" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE7AC;" 
                                                  FontSize="24"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                  Opacity="0.2"/>
                                        <Image Source="{x:Bind IconPath, Converter={StaticResource PathToImageSourceConverter}, Mode=OneWay}"
                                               Stretch="Uniform"
                                               Width="40" Height="40"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" 
                                                   FontFamily="Segoe UI Variable Text"
                                                   FontSize="14" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind Publisher}" 
                                                       FontSize="11" Opacity="0.8"/>
                                            <TextBlock Text="•" FontSize="11" Opacity="0.5"/>
                                            <TextBlock Text="{x:Bind Version}" 
                                                       FontSize="11" Opacity="0.5"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Grid.Column="2" 
                                            Background="{ThemeResource SystemAccentColor}"
                                            Opacity="0.8"
                                            CornerRadius="4" 
                                            Padding="8,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Architecture}" 
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="White"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <!-- Empty State Overlay -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                            Visibility="{x:Bind ViewModel.Apps.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter='Inverted', Mode=OneWay}">
                    <TextBlock Text="No applications found" 
                               FontFamily="Segoe UI Variable Display"
                               FontSize="30" FontWeight="Bold" Opacity="0.5"
                               HorizontalAlignment="Center"/>
                    <Button Content="Start Initial Scan" 
                            Command="{x:Bind ViewModel.ScanAppsCommand}" 
                            Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
