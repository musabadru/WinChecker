<Page
    x:Class="WinChecker.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinChecker.App.ViewModels"
    xmlns:models="using:WinChecker.Core"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 3. Page Header -->
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="Installed Applications" Style="{ThemeResource TitleLargeTextBlockStyle}"/>
            <TextBlock Text="Browse and analyze installed Win32 and UWP applications on your system." 
                       Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- 5. List Toolbar (Search & Filter) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,24,0,12" Spacing="12">
            <AutoSuggestBox PlaceholderText="Search applications..." 
                            Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QueryIcon="Find"
                            Width="300"
                            VerticalAlignment="Center"/>
            <Button Command="{x:Bind ViewModel.ScanAppsCommand}"
                    Style="{ThemeResource AccentButtonStyle}"
                    VerticalAlignment="Center">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button.Content>
            </Button>
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" 
                          Width="24" Height="24" Margin="12,0,0,0"
                          VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 5. List View -->
        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind ViewModel.Apps}"
                  SelectionMode="None"
                  Margin="0,12,0,0">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:InstalledApp">
                    <!-- Card Pattern (Surface and Background) -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,8" HorizontalAlignment="Stretch">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 13. Icons -->
                            <FontIcon Glyph="&#xE7AC;" Grid.Column="0" 
                                      FontSize="20"
                                      VerticalAlignment="Center"
                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="{x:Bind Name}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Publisher}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    <TextBlock Text="•" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind Version}" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Badge for Architecture -->
                            <Border Grid.Column="2" 
                                    Background="{ThemeResource SystemFillColorAttentionLowBrush}"
                                    CornerRadius="4" 
                                    Padding="8,2"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Architecture}" 
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemFillColorAttentionBrush}"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- 12. Empty State -->
        <StackPanel Grid.Row="2" 
                    Visibility="{x:Bind ViewModel.Apps.Count, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter='Inverted', Mode=OneWay}"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
            <FontIcon Glyph="&#xE9CE;" FontSize="64" Foreground="{ThemeResource TextFillColorDisabledBrush}"/>
            <TextBlock Text="No applications found" Style="{ThemeResource BodyStrongTextBlockStyle}" HorizontalAlignment="Center"/>
            <Button Content="Start Initial Scan" Command="{x:Bind ViewModel.ScanAppsCommand}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
