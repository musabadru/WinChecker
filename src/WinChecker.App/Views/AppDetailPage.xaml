<Page
    x:Class="WinChecker.App.Views.AppDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinChecker.App.ViewModels"
    xmlns:models="using:WinChecker.Core"
    xmlns:coremodels="using:WinChecker.Core.Models"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    mc:Ignorable="d"
    Background="Transparent">

    <animations:Implicit.ShowAnimations>
        <animations:TranslationAnimation From="0,100,0" To="0,0,0" Duration="0:0:0.25" />
        <animations:OpacityAnimation From="0" To="1" Duration="0:0:0.25" />
    </animations:Implicit.ShowAnimations>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="1000*" MaxWidth="1200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="1" Margin="32,0,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Tabs -->
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <Grid Grid.Row="0" Margin="0,32,0,24" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="60" Height="60" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE7AC;" FontSize="40" 
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                              Opacity="0.2"/>
                    <Image Source="{x:Bind ViewModel.App.IconPath, Converter={StaticResource PathToImageSourceConverter}, Mode=OneWay}"
                           Stretch="Uniform" Width="60" Height="60"/>
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                    <TextBlock Text="{x:Bind ViewModel.App.Name, Mode=OneWay}" 
                               FontFamily="Segoe UI Variable Display"
                               FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="{x:Bind ViewModel.App.Publisher, Mode=OneWay}" 
                               FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <Button Grid.Column="2" VerticalAlignment="Center" 
                        Click="OnBackClicked"
                        Style="{ThemeResource SubtleButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                        <TextBlock Text="Back"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- ProgressBar -->
                    <RowDefinition Height="Auto"/> <!-- App Info card (always visible) -->
                    <RowDefinition Height="Auto"/> <!-- Error state -->
                    <RowDefinition Height="*"/>    <!-- PE Technical Pivot -->
                </Grid.RowDefinitions>

                <ProgressBar Grid.Row="0" VerticalAlignment="Top" IsIndeterminate="True"
                             Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                             Margin="1,0,1,0"/>

                <!-- App Info Card — always visible -->
                <Border Grid.Row="1" Style="{StaticResource SurfaceCardStyle}" Margin="0,16,0,0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Application Details" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        <Grid ColumnSpacing="24" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" Opacity="0.6"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.App.Version, Mode=OneWay}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Architecture" Opacity="0.6"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.App.Architecture, Mode=OneWay}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Install Date" Opacity="0.6"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.App.InstallDate, Mode=OneWay}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Install Path" Opacity="0.6"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.App.InstallPath, Mode=OneWay}" TextWrapping="WrapWholeWords"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Error State -->
                <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                            Margin="0,16,0,0"
                            Visibility="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource IntToVisibilityConverter}, Mode=OneWay}">
                    <FontIcon Glyph="&#xE783;" FontSize="64" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                               MaxWidth="400" TextWrapping="Wrap" TextAlignment="Center"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                </StackPanel>

                <!-- PE Technical Pivot — visible only when Metadata is available -->
                <Pivot Grid.Row="3" Margin="0,8,0,0"
                       Visibility="{x:Bind ViewModel.Metadata, Converter={StaticResource IntToVisibilityConverter}, Mode=OneWay}">

                    <PivotItem Header="PE Info">
                        <ScrollViewer>
                            <StackPanel Spacing="8" Margin="0,8,0,0">
                                <Grid ColumnSpacing="24" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Subsystem" Opacity="0.6"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.Metadata.Subsystem, Mode=OneWay}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Linker Version" Opacity="0.6"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.Metadata.LinkerVersion, Mode=OneWay}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Compile Time" Opacity="0.6"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.Metadata.CompileTime, Mode=OneWay}"/>
                                </Grid>

                                <!-- VersionInfo -->
                                <Border Visibility="{x:Bind ViewModel.VersionInfoItems.Count, Converter={StaticResource IntToVisibilityConverter}, Mode=OneWay}"
                                        Margin="0,12,0,0">
                                    <ListView ItemsSource="{x:Bind ViewModel.VersionInfoItems, Mode=OneWay}" SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:VersionEntry">
                                                <Grid ColumnSpacing="16" Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{x:Bind Key}" Opacity="0.6" TextWrapping="NoWrap"/>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Value}" TextWrapping="WrapWholeWords"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>

                    <PivotItem Header="Dependencies">
                        <ListView ItemsSource="{x:Bind ViewModel.Metadata.Dependencies, Mode=OneWay}"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="coremodels:DependencyInfo">
                                    <Grid Margin="0,4" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0" Glyph="&#xE168;" FontSize="16"
                                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{x:Bind ResolvedPath}" FontSize="11" Opacity="0.6" TextWrapping="NoWrap"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Visibility="{x:Bind IsMissing, Mode=OneWay}"
                                                Background="{ThemeResource SystemFillColorCriticalBrush}"
                                                CornerRadius="4" Padding="8,2">
                                            <TextBlock Text="Missing" FontSize="10" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </PivotItem>

                    <PivotItem Header="Exports">
                        <ListView ItemsSource="{x:Bind ViewModel.Metadata.Exports, Mode=OneWay}"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{x:Bind}" Margin="0,4" FontFamily="Consolas"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </PivotItem>

                    <PivotItem Header="Manifest"
                               Visibility="{x:Bind ViewModel.Metadata.Manifest, Converter={StaticResource IntToVisibilityConverter}, Mode=OneWay}">
                        <ScrollViewer>
                            <TextBlock Text="{x:Bind ViewModel.Metadata.Manifest, Mode=OneWay}"
                                       FontFamily="Consolas" FontSize="11"
                                       TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                       Margin="0,8,0,0"/>
                        </ScrollViewer>
                    </PivotItem>
                </Pivot>
            </Grid>
        </Grid>
    </Grid>
</Page>
