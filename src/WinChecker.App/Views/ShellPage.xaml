<Page
    x:Class="WinChecker.App.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" x:Name="AppTitleBar" Height="32" Background="Transparent"/>

        <NavigationView x:Name="RootNavigationView"
                        Grid.Row="1"
                        IsSettingsVisible="True"
                        IsBackButtonVisible="Auto"
                        PaneDisplayMode="Left"
                        SelectionChanged="NavigationView_SelectionChanged">
            
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Applications" Tag="Apps" Icon="AllApps"/>
                <NavigationViewItem Content="Snapshots" Tag="Snapshots" Icon="Camera"/>
                <NavigationViewItem Content="Statistics" Tag="Stats" Icon="FourBars"/>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Page>
