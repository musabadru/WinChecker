<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:WinChecker.App.Converters">

    <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />

    <!-- Spacing System (from DESIGN_GUIDE.md) -->
    <Thickness x:Key="MicroSpacing">4</Thickness>
    <Thickness x:Key="ControlSpacing">8</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="SectionSpacing">24</Thickness>
    <Thickness x:Key="PageMargin">32</Thickness>

    <!-- Typography -->
    <StaticResource x:Key="PageTitleStyle" ResourceKey="TitleLargeTextBlockStyle" />
    <StaticResource x:Key="SectionHeaderStyle" ResourceKey="BodyStrongTextBlockStyle" />
    <StaticResource x:Key="BodyTextStyle" ResourceKey="BodyTextBlockStyle" />
    <StaticResource x:Key="CaptionTextStyle" ResourceKey="CaptionTextBlockStyle" />

    <!-- Card Style -->
    <Style x:Key="SurfaceCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>

    <!-- App Icon Styles -->
    <Style x:Key="ListIconStyle" TargetType="FontIcon">
        <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
        <Setter Property="FontSize" Value="20" />
    </Style>

</ResourceDictionary>
